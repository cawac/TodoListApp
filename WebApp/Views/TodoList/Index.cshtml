@model IEnumerable<WebApi.ViewModels.TodoListData>
@{
	ViewData["Title"] = "Todo Lists";
}

	<div class="d-flex justify-content-between align-items-center mb-3">
	<h1>Todo Lists</h1>
	<a asp-controller="TodoList" asp-action="Create" class="btn btn-primary">Create new</a>
</div>

<table class="table table-striped">
	<thead>
		<tr>
			<th>Id</th>
			<th>Title</th>
			<th>Description</th>
			<th>Created</th>
			<th>Items</th>
			<th>Actions</th>
		</tr>
	</thead>
	<tbody>
		@foreach (var item in Model ?? Enumerable.Empty<WebApi.ViewModels.TodoListData>())
	{
		<tr>
			<td>@item.Id</td>
			<td>@item.Title</td>
			<td>@item.Description</td>
			<td>@item.CreatedAt.ToString("g")</td>
			<td>@(item.Items?.Count() ?? 0)</td>
			<td>
				<a asp-controller="TodoList" asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-secondary">Details</a>
				<a asp-controller="TodoItem" asp-action="Index" asp-route-todoListId="@item.Id" class="btn btn-sm btn-info">View Tasks</a>
				<a asp-controller="TodoList" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Edit</a>
				<a asp-controller="TodoList" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
			</td>
		</tr>
	}
	</tbody>
</table>
