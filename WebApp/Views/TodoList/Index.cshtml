@model IEnumerable<WebApi.Models.TodoList>
@{
	ViewData["Title"] = "Todo Lists";
}

<div class="d-flex justify-content-between align-items-center mb-3">
	<h1>Списки задач</h1>
	<a class="btn btn-primary" href="/TodoList/Create">Создать новый</a>
</div>

<table class="table table-striped">
	<thead>
		<tr>
			<th>Id</th>
			<th>Название</th>
			<th>Описание</th>
			<th>Создано</th>
			<th></th>
		</tr>
	</thead>
	<tbody>
	@foreach (var item in Model ?? Enumerable.Empty<WebApi.Models.TodoList>())
	{
		<tr>
			<td>@item.Id</td>
			<td>@item.Title</td>
			<td>@item.Description</td>
			<td>@item.CreatedAt.ToString("g")</td>
			<td>
				<a class="btn btn-sm btn-secondary" href="/TodoList/Details/@item.Id">Details</a>
				<a class="btn btn-sm btn-primary" href="/TodoList/Edit/@item.Id">Edit</a>
				<a class="btn btn-sm btn-danger" href="/TodoList/Delete/@item.Id">Delete</a>
			</td>
		</tr>
	}
	</tbody>
</table>
