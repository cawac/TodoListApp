@model IEnumerable<WebApi.ViewModels.TodoListData>
@{
	ViewData["Title"] = "Todo Lists";
}

<div class="d-flex justify-content-between align-items-center mb-3">
	<h1>Todo Lists</h1>
	<a class="btn btn-primary" href="/TodoList/Create">Create new</a>
</div>

<table class="table table-striped">
	<thead>
		<tr>
			<th>Id</th>
			<th>Title</th>
			<th>Description</th>
			<th>Created</th>
			<th>Items</th>
			<th>Actions</th>
		</tr>
	</thead>
	<tbody>
		@foreach (var item in Model ?? Enumerable.Empty<WebApi.ViewModels.TodoListData>())
	{
		<tr>
			<td>@item.Id</td>
			<td>@item.Title</td>
			<td>@item.Description</td>
			<td>@item.CreatedAt.ToString("g")</td>
			<td>@(item.Items?.Count() ?? 0)</td>
			<td>
				<a class="btn btn-sm btn-secondary" href="/TodoList/Details/@item.Id">Details</a>
				<a class="btn btn-sm btn-info" href="/TodoItem/Index?todoListId=@item.Id">View Tasks</a>
				<a class="btn btn-sm btn-primary" href="/TodoList/Edit/@item.Id">Edit</a>
				<a class="btn btn-sm btn-danger" href="/TodoList/Delete/@item.Id">Delete</a>
			</td>
		</tr>
	}
	</tbody>
</table>
