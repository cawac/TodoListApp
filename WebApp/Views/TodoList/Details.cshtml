@model WebApi.ViewModels.TodoListData
@using System.Linq
@{
	ViewData["Title"] = $"{Model.Title} - Details";
}

<h1>@Model.Title</h1>

<p>@Model.Description</p>

<p>Created: @Model.CreatedAt</p>

<p>
	<a asp-action="Index">Back to Lists</a> |
	<a asp-controller="TodoItem" asp-action="Index" asp-route-todoListId="@Model.Id">View Tasks</a> |
	<a asp-controller="TodoItem" asp-action="Create" asp-route-todoListId="@Model.Id">Add Task</a>
</p>

<h2>Tasks</h2>

@if (Model.Items != null && Model.Items.Any())
{
	<table class="table">
		<thead>
			<tr>
				<th>Id</th>
				<th>Title</th>
				<th>Priority</th>
				<th>Due</th>
				<th>Completed</th>
				<th>Actions</th>
			</tr>
		</thead>
		<tbody>
		@foreach (var item in Model.Items)
		{
			var isOverdue = item.DueAt.HasValue && !item.IsCompleted && item.DueAt.Value < DateTimeOffset.UtcNow;
			<tr class="@(isOverdue ? "task-overdue" : "")">
				<td>@item.Id</td>
				<td>@item.Title</td>
				<td>@item.Priority</td>
				<td>@(item.DueAt?.ToString() ?? "-")</td>
				<td>@(item.IsCompleted ? "Yes" : "No")</td>
				<td>
					<a asp-controller="TodoItem" asp-action="Details" asp-route-id="@item.Id">Details</a> |
					<a asp-controller="TodoItem" asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
					<a asp-controller="TodoItem" asp-action="Delete" asp-route-id="@item.Id">Delete</a>
				</td>
			</tr>
		}
		</tbody>
	</table>
}
else
{
	<p>No tasks in this list yet.</p>
}
