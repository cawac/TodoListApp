@model WebApi.ViewModels.TodoListData
@{
	ViewData["Title"] = "Delete Todo List";
}

<h1>Delete Todo List</h1>

<div class="alert alert-warning">
	Are you sure you want to delete the list "@Model.Title"?
</div>

<form method="post" asp-action="DeleteConfirmed">
	<input type="hidden" asp-for="Id" />
	<button type="submit" class="btn btn-danger">Delete</button>
	<a class="btn btn-secondary" href="/TodoList">Cancel</a>
</form>
