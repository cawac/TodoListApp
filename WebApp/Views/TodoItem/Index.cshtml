@model IEnumerable<WebApi.ViewModels.TodoItemData>

@{
	ViewData["Title"] = "Tasks";
}

<h1>Tasks</h1>

<table class="table">
	<thead>
		<tr>
			<th>Id</th>
			<th>Title</th>
			<th>Priority</th>
			<th>Due</th>
			<th>Completed</th>
			<th></th>
		</tr>
	</thead>
	<tbody>
	@foreach(var item in Model)
	{
		<tr class="@(item.DueAt.HasValue && !item.IsCompleted && item.DueAt.Value < DateTimeOffset.UtcNow ? "task-overdue" : "")">
			<td>@item.Id</td>
			<td>
				@if(item.DueAt.HasValue && !item.IsCompleted && item.DueAt.Value < DateTimeOffset.UtcNow)
				{
					<span class="overdue-icon"></span>
				}
				@item.Title
			</td>
			<td>@item.Priority</td>
			<td>@(item.DueAt?.ToString() ?? "-")</td>
			<td>@(item.IsCompleted ? "Yes" : "No")</td>
			<td>
				<a asp-action="Details" asp-controller="TodoItem" asp-route-id="@item.Id">Details</a>
				|
				<form asp-action="ToggleStatus" asp-controller="TodoItem" method="post" class="d-inline">
					<input type="hidden" name="id" value="@item.Id" />
					<input type="hidden" name="returnUrl" value="@(ViewContext.HttpContext.Request.Path + ViewContext.HttpContext.Request.QueryString)" />
					<button type="submit" class="btn btn-sm btn-link">@(item.IsCompleted ? "Mark active" : "Mark completed")</button>
				</form>
			</td>
		</tr>
	}
	</tbody>
</table>
